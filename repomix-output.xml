# OpenBridge API-Mode Reference
#
# This file is documentation-only. Runtime configuration is sourced from
# ~/.config/openbridge/bridge.env (generated by `openbridge setup`).
#
# OpenBridge now uses OpenCode server APIs (`opencode serve`) and per-chat
# sessions. Legacy monitor/analyzer YAML modes are not used.

telegram:
  bot_token: "${TELEGRAM_BOT_TOKEN}"
  allowed_chat_ids: "${TELEGRAM_ALLOWED_CHAT_IDS}"
  allow_all_chats: "${TELEGRAM_ALLOW_ALL_CHATS}"

opencode:
  model: "${OPENCODE_MODEL}"
  working_dir: "${OPENCODE_WORKING_DIR}"
  timeout_seconds: "${OPENCODE_TIMEOUT_SECONDS}"
  max_concurrent: "${OPENCODE_MAX_CONCURRENT}"
  api:
    base_url: "${OPENCODE_API_BASE_URL}"
    username: "${OPENCODE_API_USERNAME}"
    password: "${OPENCODE_API_PASSWORD}"
    timeout_seconds: "${OPENCODE_API_TIMEOUT_SECONDS}"
