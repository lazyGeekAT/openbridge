    api_key: "${OPENBRIDGE_INPUT_LLM_API_KEY}"
    base_url: "${OPENBRIDGE_INPUT_LLM_BASE_URL}"
    litellm_port: "${OPENBRIDGE_INPUT_LLM_LITELLM_PORT}"
